<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.senai.controller.ConversorController">
   <children>
      <Label text="Conversor de moedas">
         <VBox.margin>
            <Insets top="20.0" />
         </VBox.margin>
      </Label>
      <HBox alignment="CENTER" prefHeight="83.0" prefWidth="600.0">
         <children>
            <Label text="Digite o valor em R$:">
               <HBox.margin>
                  <Insets right="10.0" />
               </HBox.margin>
            </Label>
            <TextField fx:id="valor_real" />
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="90.0" prefWidth="600.0">
         <children>
            <Button mnemonicParsing="false" onAction="#dolar" text="Dolar" />
            <Button mnemonicParsing="false" onAction="#euro" text="Euro">
               <HBox.margin>
                  <Insets left="60.0" right="60.0" />
               </HBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#libra" text="Libra" />
         </children>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </HBox>
      <Label fx:id="informa_moeda" />
      <Label fx:id="valor_final" />
   </children>
</VBox>
